# ── AI Provider Keys ───────────────────────────────────────────
# Get your Groq key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Not used by NutriGuard (kept for config compatibility)
GEMINI_API_KEY=not_used
ANTHROPIC_API_KEY=not_used

# ── App Settings ───────────────────────────────────────────────
APP_ENV=development
APP_VERSION=0.1.0
LOG_LEVEL=INFO
RATE_LIMIT_PER_MINUTE=10

# ── Storage ────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db

# ── Server ─────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000